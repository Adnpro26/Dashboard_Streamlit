# config/registry.py

from utils.TranscoManagerFunc import TranscoManager

_transco_manager = None


def init_transco(config_path):
    global _transco_manager
    
    _transco_manager = TranscoManager(config_path)
    _transco_manager.load()


def get_transco():
    if _transco_manager is None:
        raise ValueError("Transco non initialisé")
    return _transco_manager


def get_list(name):
    return get_transco().config["lists"].get(name)


