def compute_calc_indicator(df, indicator_name, cfg):
    dims = cfg["dimensions"]
    a, b = cfg["formula"]["operands"]

    df_a = df[df["Indicateur"] == a]
    df_b = df[df["Indicateur"] == b]

    merged = df_a.merge(
        df_b,
        on=dims,
        suffixes=("_a", "_b")
    )

    merged["Valeur"] = merged["Valeur_a"] - merged["Valeur_b"]

    result = merged[dims + ["Valeur"]].copy()
    result["Indicateur"] = indicator_name
    result["Source"] = "Computed"

    return result
