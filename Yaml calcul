    ("Q4 2024 Change actuel", "FR", "IFRS", "CA", "resultat"): X,
    ("Q4 2024 Change constant", "FR", "IFRS", "CA", "resultat"): Y,
    
    ("Q4 2024 Change actuel", "FR", "IFRS", "CA", "exceptionnel"): x,
