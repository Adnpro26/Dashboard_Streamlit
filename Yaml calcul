def compute_delta_from_yaml(data_indexed, rule, pays, norme, indicateur):

    key_from = (rule["from"], pays, norme, indicateur)
    key_to = (rule["to"], pays, norme, indicateur)

    val_from = data_indexed.get(key_from, 0)
    val_to = data_indexed.get(key_to, 0)

    return val_to - val_from



