def compute_effet_scope_total(data_indexed, rule, pays, norme, indicateur):
    total_delta = 0
    
    for niveau in rule["niveaux"]:
        key_from = (rule["from"], pays, norme, indicateur, niveau)
        key_to   = (rule["to"],   pays, norme, indicateur, niveau)
        
        val_from = data_indexed.get(key_from, 0)
        val_to   = data_indexed.get(key_to, 0)
        
        total_delta += val_to - val_from
    
    return total_delta

